# ==================== POSTGRES ====================
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5433
POSTGRES_DB_NAME=your_db_name
POSTGRES_DB_USER=your_db_user
POSTGRES_DB_PASSWORD=your_db_password

# ==================== ELASTICSEARCH ====================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=your_es_username
ELASTICSEARCH_PASSWORD=your_es_password
QMS_INDEX_NAME=your-index-name

# ==================== N8N ====================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_n8n_user
N8N_BASIC_AUTH_PASSWORD=your_n8n_password

# ==================== LIVEKIT ====================
# Server-side: LiveKit container reads this to register API keys.
# Format is YAML — space after the colon is REQUIRED.
LIVEKIT_KEYS=YOUR_API_KEY: YOUR_API_SECRET

# Client-side: your backend/agent/frontend reads these. Must match LIVEKIT_KEYS above.
LIVEKIT_API_KEY=YOUR_API_KEY
LIVEKIT_API_SECRET=YOUR_API_SECRET
LIVEKIT_URL=ws://localhost:7880
