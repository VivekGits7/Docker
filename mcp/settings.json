{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-github", "/server/github-mcp-server", "stdio"]
    },
    "gitlab": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-gitlab", "npx", "-y", "mcp-remote", "https://gitlab.com/api/v4/mcp"]
    },
    "postgres": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-postgres", "sh", "-c", "npx -y @modelcontextprotocol/server-postgres $POSTGRES_CONNECTION_STRING"]
    },
    "swagger": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-swagger", "sh", "-c", "npx -y mcp-openapi --spec $OPENAPI_SPEC_URL --base-url $API_BASE_URL"]
    },
    "postman": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-postman", "sh", "-c", "npx -y @postman/postman-mcp-server --full"]
    },
    "rest-api": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-rest-api", "npx", "-y", "dkmaker-mcp-rest-api"]
    },
    "google-map": {
      "command": "docker",
      "args": ["exec", "-i", "mcp-google-map", "npx", "-y", "@cablate/mcp-google-map", "--stdio"]
    }
  }
}
