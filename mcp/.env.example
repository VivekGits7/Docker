# GitHub MCP Server
GITHUB_TOKEN=your_github_personal_access_token

# GitLab MCP Server
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_URL=gitlab.com

# PostgreSQL MCP Server
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_NAME=your_db_name
POSTGRES_DB_USER=your_db_user
POSTGRES_DB_PASSWORD=your_db_password

# Swagger MCP Server
SWAGGER_OPENAPI_URL=http://host.docker.internal:8000/openapi.json
SWAGGER_API_BASE_URL=http://host.docker.internal:8000

# REST API Tester MCP Server
REST_BASE_URL=http://host.docker.internal:8000
# Auth (choose one - leave others empty)
REST_AUTH_BEARER=your_jwt_or_bearer_token
REST_AUTH_BASIC_USERNAME=
REST_AUTH_BASIC_PASSWORD=
REST_AUTH_APIKEY_HEADER_NAME=
REST_AUTH_APIKEY_VALUE=
REST_ENABLE_SSL_VERIFY=true
REST_RESPONSE_SIZE_LIMIT=10000

# Postman MCP Server
POSTMAN_API_KEY=your-postman-api-key-here

# Google OAuth (for Gmail & Calendar)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps MCP Server
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Razorpay MCP Server
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Optional: comma-separated toolsets (default: all)
RAZORPAY_TOOLSETS=all
# Optional: set to "true" for read-only mode
RAZORPAY_READ_ONLY=false
